@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="text-muted d-none d-md-inline">Cucina Canina - Gestiune Internă</span>
        </div>

        <article class="content px-4">
            <div class="container-fluid py-4">
                @Body
            </div>
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    A apărut o eroare neașteptată.
    <a href="" class="reload">Reîncarcă</a>
    <a class="dismiss">🗙</a>
</div>
