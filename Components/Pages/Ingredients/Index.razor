@page "/ingredients"
@inject IngredientService IngredientService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-basket-fill me-2"></i> Gestiune Ingrediente</h1>
    <a href="/ingredients/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Adaugă Ingredient
    </a>
</div>

<div class="card mb-4">
    <div class="row g-3 align-items-center">
        <div class="col-auto">
            <i class="bi bi-search text-muted"></i>
        </div>
        <div class="col-md-8">
            <input type="text" class="form-control border-0" placeholder="Caută după nume ingredient..." 
                   @bind="SearchTerm" @bind:event="oninput" />
        </div>
        <div class="col-md-4">
            <select class="form-select" @bind="SelectedCategoryFilter">
                <option value="all">Toate categoriile</option>
                <option value="@IngredientCategory.RawFood.ToString()">@GetCategoryLabel(IngredientCategory.RawFood)</option>
                <option value="@IngredientCategory.CookedFood.ToString()">@GetCategoryLabel(IngredientCategory.CookedFood)</option>
                <option value="@IngredientCategory.Vitamins.ToString()">@GetCategoryLabel(IngredientCategory.Vitamins)</option>
            </select>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(deleteErrorMessage))
{
    <div class="alert alert-warning" role="alert">
        @deleteErrorMessage
    </div>
}

@if (ingredients == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Se încarcă...</span>
        </div>
        <p class="mt-2 text-muted">Se încarcă ingredientele...</p>
    </div>
}
else if (!ingredients.Any())
{
    <div class="card text-center py-5">
        <i class="bi bi-emoji-smile text-muted" style="font-size: 3rem;"></i>
        <h3 class="mt-3">Nu există ingrediente</h3>
        <p class="text-muted">Începe prin a adăuga primul tău ingredient pentru rețete.</p>
        <div>
            <a href="/ingredients/create" class="btn btn-primary mt-2">
                Adaugă Primul Ingredient
            </a>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th style="border-top-left-radius: 12px;">Nume</th>
                    <th>Categorie</th>
                    <th>Preț/Kg</th>
                    <th>Factor</th>
                    <th>Preț Recom./Kg</th>
                    <th class="text-center" style="border-top-right-radius: 12px;">Acțiuni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in GetPagedIngredients())
                {
                    <tr class="ingredient-row">
                        <td class="fw-bold">@item.Name</td>
                        <td>
                            <span class="badge @GetCategoryBadgeClass(item.Category)">
                                @GetCategoryLabel(item.Category)
                            </span>
                        </td>
                        <td class="fw-bold text-brown">@IngredientService.CalculateRealCostPerKg(item).ToString("N2") Lei</td>
                        <td>x @GetDisplayMultiplier(item).ToString("N2")</td>
                        <td class="text-success fw-bold">
                            @IngredientService.CalculateRecommendedPricePerKg(item).ToString("N2") Lei
                        </td>
                        <td class="text-center">
                            <a href="/ingredients/edit/@item.Id" class="btn btn-sm btn-outline-primary me-2">
                                <i class="bi bi-pencil-square"></i> Editează
                            </a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteIngredient(item)">
                                <i class="bi bi-trash"></i> Șterge
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted small">
                Pagina @currentPage din @TotalPages (@FilteredCount rezultate)
            </div>
            <div class="btn-group" role="group" aria-label="Paginare ingrediente">
                <button class="btn btn-outline-secondary" @onclick="PreviousPage" disabled="@(currentPage == 1)">
                    <i class="bi bi-chevron-left"></i> Anterior
                </button>
                <button class="btn btn-outline-secondary" @onclick="NextPage" disabled="@(currentPage == TotalPages)">
                    Următor <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    }
}

@code {
    private List<Ingredient>? ingredients;
    private string searchTerm = "";
    private string? deleteErrorMessage;
    private string selectedCategoryFilter = "all";
    private int currentPage = 1;
    private const int PageSize = 10;

    private string SearchTerm
    {
        get => searchTerm;
        set
        {
            if (searchTerm == value) return;
            searchTerm = value;
            currentPage = 1;
        }
    }

    private string SelectedCategoryFilter
    {
        get => selectedCategoryFilter;
        set
        {
            if (selectedCategoryFilter == value) return;
            selectedCategoryFilter = value;
            currentPage = 1;
        }
    }

    private int FilteredCount => GetFilteredIngredients().Count();
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredCount / (double)PageSize));

    protected override async Task OnInitializedAsync()
    {
        ingredients = await IngredientService.GetAllIngredientsAsync();
    }

    private IEnumerable<Ingredient> GetFilteredIngredients()
    {
        if (ingredients == null) return Enumerable.Empty<Ingredient>();

        IEnumerable<Ingredient> filtered = ingredients;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            filtered = filtered.Where(i => i.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        if (SelectedCategoryFilter != "all" && Enum.TryParse<IngredientCategory>(SelectedCategoryFilter, out var category))
        {
            filtered = filtered.Where(i => i.Category == category);
        }

        return filtered;
    }

    private IEnumerable<Ingredient> GetPagedIngredients()
    {
        var filtered = GetFilteredIngredients();
        var totalPages = TotalPages;
        if (currentPage > totalPages) currentPage = totalPages;
        return filtered.Skip((currentPage - 1) * PageSize).Take(PageSize);
    }

    private decimal GetDisplayMultiplier(Ingredient ingredient)
        => ingredient.Category == IngredientCategory.CookedFood
            ? (ingredient.CookedMultiplier ?? 1.0m)
            : ingredient.RecommendedPriceMultiplier;

    private void PreviousPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private string GetCategoryLabel(IngredientCategory category) => category switch
    {
        IngredientCategory.RawFood => "Aliment Crud",
        IngredientCategory.CookedFood => "Aliment Gătit",
        IngredientCategory.Vitamins => "Vitamine",
        _ => category.ToString()
    };

    private string GetCategoryBadgeClass(IngredientCategory category) => category switch
    {
        IngredientCategory.RawFood => "bg-info text-dark",
        IngredientCategory.CookedFood => "bg-warning text-dark",
        IngredientCategory.Vitamins => "bg-success text-white",
        _ => "bg-secondary"
    };

    private async Task DeleteIngredient(Ingredient item)
    {
        deleteErrorMessage = null;
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Sigur dorești să ștergi ingredientul '{item.Name}'?");
        if (confirmed)
        {
            try
            {
                await IngredientService.DeleteIngredientAsync(item.Id);
                ingredients = await IngredientService.GetAllIngredientsAsync();
                if (currentPage > TotalPages) currentPage = TotalPages;
            }
            catch (InvalidOperationException ex)
            {
                deleteErrorMessage = ex.Message;
            }
        }
    }
}
