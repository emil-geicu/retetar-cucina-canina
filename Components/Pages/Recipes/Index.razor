@page "/recipes"
@page "/"
@inject RecipeService RecipeService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-journal-text me-2"></i> Panou Rețete</h1>
    <a href="/recipes/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Adaugă Rețetă Nouă
    </a>
</div>

<div class="card mb-4">
    <div class="row g-3 align-items-center">
        <div class="col-auto">
            <i class="bi bi-search text-muted"></i>
        </div>
        <div class="col">
            <input type="text" class="form-control border-0" placeholder="Caută după nume rețetă sau ingredient..." 
                   @bind="searchTerm" @bind:event="oninput" />
        </div>
    </div>
</div>

@if (recipes == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Se încarcă...</span>
        </div>
        <p class="mt-2 text-muted">Se încarcă rețetele...</p>
    </div>
}
else if (!recipes.Any())
{
    <div class="card text-center py-5 shadow-sm">
        <i class="bi bi-journal-text text-muted" style="font-size: 3rem;"></i>
        <h3 class="mt-3">Nu există rețete create încă</h3>
        <p class="text-muted">Poți începe prin a adăuga prima rețetă folosind butonul de mai sus.</p>
        <div>
            <a href="/recipes/create" class="btn btn-primary mt-2">
                Adaugă Primul Rețetă
            </a>
        </div>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var recipe in GetFilteredRecipes())
        {
            var totalRecommended = RecipeService.CalculateTotalRecommendedPrice(recipe);
            var difference = recipe.IdealPrice - totalRecommended;
            var statusColor = RecipeService.GetStatusColor(difference);
            
            <div class="col">
                <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden">
                    <div style="height: 6px; background-color: @statusColor; width: 100%; position: absolute; top: 0; left: 0;"></div>
                    
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <h5 class="card-title fw-bold">@recipe.Name</h5>
                        </div>
                        
                        <div class="my-4">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Preț Ideal:</span>
                                <b>@recipe.IdealPrice.ToString("N2") Lei</b>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Preț Recom.:</span>
                                <b>@FormatLei(totalRecommended) Lei</b>
                            </div>
                            <div class="d-flex justify-content-between pt-2 border-top">
                                <span class="text-muted">Diferență:</span>
                                <b style="color: @statusColor;">
                                    @(difference >= 0 ? "+" : "")@FormatLei(difference) Lei
                                </b>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="/recipes/details/@recipe.Id" class="btn btn-sm btn-outline-primary flex-grow-1">
                                <i class="bi bi-eye"></i> Detalii
                            </a>
                            <a href="/recipes/edit/@recipe.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRecipe(recipe)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="card-footer bg-transparent border-0 pt-0 pb-3 text-center">
                        <small class="text-muted">
                            <i class="bi bi-basket me-1"></i> @recipe.RecipeIngredients.Count ingrediente
                        </small>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Recipe>? recipes;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        recipes = await RecipeService.GetAllRecipesAsync();
    }

    private IEnumerable<Recipe> GetFilteredRecipes()
    {
        if (recipes == null) return Enumerable.Empty<Recipe>();
        
        if (string.IsNullOrWhiteSpace(searchTerm))
            return recipes;
            
        return recipes.Where(r => 
            r.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
            r.RecipeIngredients.Any(ri => ri.Ingredient!.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task DeleteRecipe(Recipe recipe)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Sigur dorești să ștergi rețeta '{recipe.Name}'?");
        if (confirmed)
        {
            await RecipeService.DeleteRecipeAsync(recipe.Id);
            recipes = await RecipeService.GetAllRecipesAsync();
        }
    }

    private static string FormatLei(decimal amount, int normalDecimals = 2, int tinyDecimals = 6, decimal tinyThreshold = 0.01m)
        => amount != 0 && Math.Abs(amount) < tinyThreshold
            ? amount.ToString($"N{tinyDecimals}")
            : amount.ToString($"N{normalDecimals}");
}
